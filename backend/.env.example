# ─────────────────────────────────────────────────────────────
# DocuChat backend environment
# Copy to `.env` and fill in values. Do not commit `.env`.
# ─────────────────────────────────────────────────────────────

# OpenAI (required)
# Get your key at: https://platform.openai.com/account/api-keys
OPENAI_API_KEY=your-openai-api-key-here

# Optional HTTP/HTTPS proxy for api.openai.com (set if your network blocks it)
# Example: OPENAI_PROXY=http://127.0.0.1:7890
OPENAI_PROXY=

# Django core
# Either `DJANGO_SECRET_KEY` or `SECRET_KEY` is accepted (DJANGO_* wins).
# Generate: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=django-insecure-replace-this-in-production
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# CORS — comma-separated list of allowed frontend origins
CORS_ALLOWED_ORIGINS=http://localhost:5173
